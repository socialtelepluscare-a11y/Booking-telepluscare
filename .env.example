# Server
PORT=3000
APP_BASE_URL=http://localhost:3000
DATA_DIR=./data

# Database driver: "sqlite" (default, file-based) or "mysql" (Hostinger VPS).
# Leave as sqlite until the MySQL data layer is enabled and verified.
DB_DRIVER=sqlite
# MySQL settings (used only when DB_DRIVER=mysql).
# When the app runs on the SAME VPS as MySQL, use 127.0.0.1 (fast, no IP whitelisting).
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=u435532808_user
# MYSQL_PASSWORD=
# MYSQL_DATABASE=u435532808_Booking

# Admin page login
ADMIN_USER=admin
ADMIN_PASSWORD=change-this-password

# Confirmation email SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="TelePlus Care <booking@telepluscare.com>"

# Appointment reminders
REMINDERS_ENABLED=true
REMINDER_MINUTES_BEFORE=30

# Patient intake uploads
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_BYTES=10485760

# reCAPTCHA v3 spam protection
# RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=

# Square payments
SQUARE_ENVIRONMENT=sandbox
# SQUARE_ACCESS_TOKEN=
# SQUARE_LOCATION_ID=
# SQUARE_API_VERSION=2026-05-20

# Square webhooks (automatic paid/refunded status updates).
# In Square Dashboard > Webhooks, add a subscription pointing to:
#   https://your-domain/api/square/webhook
# Subscribe to payment.updated and refund.updated, then paste the signature key here.
# SQUARE_WEBHOOK_SIGNATURE_KEY=
# Optional: set this only if your public webhook URL differs from APP_BASE_URL + /api/square/webhook
# SQUARE_WEBHOOK_URL=

# Production integrations you will need to add later
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Future direct Google Calendar integration
# GOOGLE_CALENDAR_ID=
# GOOGLE_SERVICE_ACCOUNT_JSON=
